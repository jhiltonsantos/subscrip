# ===========================================
# DATABASE
# ===========================================

# Option 1: Docker local (recommended for development)
# Run: docker compose up -d
DATABASE_URL=postgresql://subscrip:subscrip_dev@localhost:5432/subscrip
DIRECT_URL=postgresql://subscrip:subscrip_dev@localhost:5432/subscrip

# Option 2: Neon (production / cloud development)
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/subscrip?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/subscrip?sslmode=require

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development

# ===========================================
# EMAIL (Resend)
# ===========================================
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=Subscrip <noreply@subscrip.dev>

# ===========================================
# AUTHENTICATION (Better Auth)
# ===========================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000